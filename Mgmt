// ---------- Notice Board ----------
function NoticeBoardView({ notices, setNotices }) {
  const [filter, setFilter] = useState("All");
  const [showAdd, setShowAdd] = useState(false);
  const [form, setForm] = useState({ category: "Prayer", title: "", body: "", color: "rose" });

  const categories = ["All", "Prayer", "Volunteer", "Lost & Found", "Thanks", "Notice"];
  const filtered = filter === "All" ? notices : notices.filter(n => n.category === filter);

  const catColor = { Prayer: "rose", Volunteer: "amber", "Lost & Found": "sky", Thanks: "emerald", Notice: "violet" };

  const addNotice = () => {
    if (!form.title || !form.body) return;
    setNotices([{ ...form, id: Date.now(), author: "Weslyn J.", date: new Date().toISOString().slice(0, 10), color: catColor[form.category] || "amber" }, ...notices]);
    setForm({ category: "Prayer", title: "", body: "", color: "rose" });
    setShowAdd(false);
  };

  return (
    <div>
      <SectionHeader
        title="Notice Board"
        subtitle="Prayer requests, volunteer calls, and community notes"
        action={
          <button onClick={() => setShowAdd(true)} className="bg-stone-900 text-amber-50 px-4 py-2.5 rounded-lg text-sm font-medium flex items-center gap-2 hover:bg-stone-800">
            <Plus className="w-4 h-4" /> Pin a notice
          </button>
        }
      />

      <div className="flex gap-2 mb-6 flex-wrap">
        {categories.map(c => (
          <button
            key={c}
            onClick={() => setFilter(c)}
            className={`px-3 py-1.5 rounded-full text-xs uppercase tracking-wider transition ${
              filter === c ? "bg-stone-900 text-amber-50" : "bg-white border border-stone-200 text-stone-600 hover:bg-stone-50"
            }`}
          >
            {c}
          </button>
        ))}
      </div>

      <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        {filtered.map((n, i) => (
          <div
            key={n.id}
            className={`relative border-2 rounded-xl p-5 ${colorMap[n.color]} shadow-sm hover:shadow-md transition`}
            style={{ transform: `rotate(${(i % 3 - 1) * 0.4}deg)` }}
          >
            <Pin className="absolute -top-2 -right-2 w-5 h-5 text-stone-700 rotate-12" />
            <div className="flex items-center justify-between mb-2">
              <span className={`text-[10px] uppercase tracking-wider px-2 py-0.5 rounded ${tagColorMap[n.color]}`}>{n.category}</span>
              <span className="text-[10px] text-stone-600">{n.date}</span>
            </div>
            <h3 className="font-serif text-lg mb-2">{n.title}</h3>
            <p className="text-sm opacity-80 mb-3">{n.body}</p>
            <p className="text-xs opacity-60">— {n.author}</p>
          </div>
        ))}
      </div>

      {showAdd && (
        <Modal onClose={() => setShowAdd(false)} title="Pin a new notice">
          <div className="space-y-4">
            <div>
              <label className="text-xs uppercase tracking-wider text-stone-500 font-medium">Category</label>
              <select
                value={form.category}
                onChange={e => setForm({ ...form, category: e.target.value, color: catColor[e.target.value] })}
                className="w-full mt-1 px-3 py-2 border border-stone-200 rounded-lg text-sm"
              >
                {categories.filter(c => c !== "All").map(c => <option key={c}>{c}</option>)}
              </select>
            </div>
            <Input label="Title" value={form.title} onChange={v => setForm({ ...form, title: v })} />
            <div>
              <label className="text-xs uppercase tracking-wider text-stone-500 font-medium">Message</label>
              <textarea
                value={form.body}
                onChange={e => setForm({ ...form, body: e.target.value })}
                rows={4}
                className="w-full mt-1 px-3 py-2 border border-stone-200 rounded-lg text-sm focus:outline-none focus:border-amber-700"
              />
            </div>
          </div>
          <div className="flex justify-end gap-2 mt-6">
            <button onClick={() => setShowAdd(false)} className="px-4 py-2 text-sm text-stone-600">Cancel</button>
            <button onClick={addNotice} className="px-4 py-2 text-sm bg-stone-900 text-amber-50 rounded-lg hover:bg-stone-800">Pin notice</button>
          </div>
        </Modal>
      )}
    </div>
  );
}

// ---------- Announcements ----------
function AnnouncementsView({ announcements, setAnnouncements }) {
  const [showAdd, setShowAdd] = useState(false);
  const [form, setForm] = useState({ title: "", body: "", start: "", end: "", priority: "normal", channels: [] });

  const toggleChannel = (ch) => {
    const has = form.channels.includes(ch);
    setForm({ ...form, channels: has ? form.channels.filter(c => c !== ch) : [...form.channels, ch] });
  };

  const add = () => {
    if (!form.title) return;
    setAnnouncements([{ ...form, id: Date.now() }, ...announcements]);
    setForm({ title: "", body: "", start: "", end: "", priority: "normal", channels: [] });
    setShowAdd(false);
  };

  const allChannels = ["Notice Board", "Email", "Website", "Facebook", "Instagram"];

  return (
    <div>
      <SectionHeader
        title="Announcements"
        subtitle="Scheduled messages pushed across your chosen channels"
        action={
          <button onClick={() => setShowAdd(true)} className="bg-stone-900 text-amber-50 px-4 py-2.5 rounded-lg text-sm font-medium flex items-center gap-2 hover:bg-stone-800">
            <Megaphone className="w-4 h-4" /> New announcement
          </button>
        }
      />

      <div className="space-y-4">
        {announcements.map(a => (
          <div key={a.id} className="bg-white border border-stone-200 rounded-xl p-6 hover:shadow-sm transition">
            <div className="flex items-start justify-between mb-3">
              <div className="flex items-center gap-3">
                <div className={`p-2 rounded-lg ${a.priority === "high" ? "bg-rose-100 text-rose-800" : "bg-amber-50 text-amber-800"}`}>
                  <Megaphone className="w-5 h-5" />
                </div>
                <div>
                  <h3 className="font-serif text-xl text-stone-900">{a.title}</h3>
                  <p className="text-xs text-stone-500 flex items-center gap-1 mt-0.5">
                    <Clock className="w-3 h-3" /> {a.start} → {a.end}
                  </p>
                </div>
              </div>
              {a.priority === "high" && (
                <span className="text-[10px] uppercase tracking-wider bg-rose-100 text-rose-800 px-2 py-1 rounded">High priority</span>
              )}
            </div>
            <p className="text-sm text-stone-700 mb-4">{a.body}</p>
            <div className="flex gap-2 flex-wrap pt-3 border-t border-stone-100">
              <span className="text-xs text-stone-500 uppercase tracking-wider">Channels:</span>
              {a.channels.map(ch => (
                <span key={ch} className="text-xs bg-stone-100 text-stone-700 px-2 py-1 rounded">{ch}</span>
              ))}
            </div>
          </div>
        ))}
      </div>

      {showAdd && (
        <Modal onClose={() => setShowAdd(false)} title="New announcement">
          <div className="space-y-4">
            <Input label="Title" value={form.title} onChange={v => setForm({ ...form, title: v })} />
            <div>
              <label className="text-xs uppercase tracking-wider text-stone-500 font-medium">Message</label>
              <textarea
                value={form.body}
                onChange={e => setForm({ ...form, body: e.target.value })}
                rows={3}
                className="w-full mt-1 px-3 py-2 border border-stone-200 rounded-lg text-sm focus:outline-none focus:border-amber-700"
              />
            </div>
            <div className="grid grid-cols-2 gap-3">
              <Input label="Start date" value={form.start} onChange={v => setForm({ ...form, start: v })} />
              <Input label="End date" value={form.end} onChange={v => setForm({ ...form, end: v })} />
            </div>
            <div>
              <label className="text-xs uppercase tracking-wider text-stone-500 font-medium">Priority</label>
              <select
                value={form.priority}
                onChange={e => setForm({ ...form, priority: e.target.value })}
                className="w-full mt-1 px-3 py-2 border border-stone-200 rounded-lg text-sm"
              >
                <option value="normal">Normal</option>
                <option value="high">High</option>
              </select>
            </div>
            <div>
              <label className="text-xs uppercase tracking-wider text-stone-500 font-medium mb-2 block">Publish to</label>
              <div className="flex gap-2 flex-wrap">
                {allChannels.map(ch => (
                  <button
                    key={ch}
                    onClick={() => toggleChannel(ch)}
                    className={`px-3 py-1.5 rounded-full text-xs transition ${
                      form.channels.includes(ch) ? "bg-stone-900 text-amber-50" : "bg-stone-100 text-stone-600"
                    }`}
                  >
                    {ch}
                  </button>
                ))}
              </div>
            </div>
          </div>
          <div className="flex justify-end gap-2 mt-6">
            <button onClick={() => setShowAdd(false)} className="px-4 py-2 text-sm text-stone-600">Cancel</button>
            <button onClick={add} className="px-4 py-2 text-sm bg-stone-900 text-amber-50 rounded-lg hover:bg-stone-800">Publish</button>
          </div>
        </Modal>
      )}
    </div>
  );
}

