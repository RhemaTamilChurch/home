  return (
    <div>
      <SectionHeader
        title="Attendance"
        subtitle="Sunday Service · April 19, 2026"
        action={<div className="text-right"><p className="text-xs uppercase tracking-wider text-stone-500">Present</p><p className="font-serif text-2xl text-stone-900">{present.size} / {people.length}</p></div>}
