      <div className="bg-white border border-stone-200 rounded-xl p-4">
        <div className="grid grid-cols-1 md:grid-cols-2 gap-2">
          {people.map(p => {
            const checked = present.has(p.id);
            return (
              <button key={p.id} onClick={() => toggle(p.id)}
                className={`flex items-center gap-3 p-3 rounded-lg text-left transition ${checked ? "bg-emerald-50 border border-emerald-200" : "bg-stone-50 border border-stone-100 hover:bg-stone-100"}`}>
                <div className={`w-5 h-5 rounded border-2 flex items-center justify-center ${checked ? "bg-emerald-700 border-emerald-700" : "border-stone-300"}`}>
                  {checked && <CheckSquare className="w-3 h-3 text-white" />}
                </div>
                <div className="w-8 h-8 rounded-full bg-gradient-to-br from-amber-200 to-amber-400 flex items-center justify-center text-amber-900 text-xs font-medium">
                  {p.first[0]}{p.last[0]}
