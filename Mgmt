function SocialView({ posts, setPosts }) {
  const [composing, setComposing] = useState(false);
  const [draft, setDraft] = useState({ platforms: [], content: "", when: "" });

  const platformIcon = { Facebook: Facebook, Instagram: Instagram, YouTube: Youtube };
  const platformColor = {
    Facebook: "bg-blue-50 text-blue-700 border-blue-200",
    Instagram: "bg-pink-50 text-pink-700 border-pink-200",
    YouTube: "bg-red-50 text-red-700 border-red-200",
  };

  const connections = [
    { name: "Facebook", connected: true, handle: "@lanternchurch", icon: Facebook, color: "text-blue-700", bg: "bg-blue-50" },
    { name: "Instagram", connected: true, handle: "@lantern.church", icon: Instagram, color: "text-pink-700", bg: "bg-pink-50" },
    { name: "YouTube", connected: true, handle: "Lantern Church", icon: Youtube, color: "text-red-700", bg: "bg-red-50" },
    { name: "Website", connected: true, handle: "lanterncounselling.com.au", icon: Globe, color: "text-stone-700", bg: "bg-stone-100" },
  ];

  const togglePlatform = (p) => {
    const has = draft.platforms.includes(p);
    setDraft({ ...draft, platforms: has ? draft.platforms.filter(x => x !== p) : [...draft.platforms, p] });
  };

  const publish = () => {
    if (!draft.content || draft.platforms.length === 0) return;
    const newPosts = draft.platforms.map(p => ({
      id: Date.now() + Math.random(),
      platform: p,
      content: draft.content,
      status: draft.when ? "Scheduled" : "Published",
      when: draft.when || new Date().toISOString().slice(0, 16).replace("T", " "),
      engagement: draft.when ? null : { likes: 0, comments: 0, shares: 0 },
    }));
    setPosts([...newPosts, ...posts]);
    setDraft({ platforms: [], content: "", when: "" });
    setComposing(false);
  };

  return (
    <div>
      <SectionHeader
        title="Social Media"
        subtitle="Publish once, post everywhere"
        action={
          <button onClick={() => setComposing(true)} className="bg-stone-900 text-amber-50 px-4 py-2.5 rounded-lg text-sm font-medium flex items-center gap-2 hover:bg-stone-800">
            <Share2 className="w-4 h-4" /> Create post
          </button>
        }
      />

      <div className="grid grid-cols-1 md:grid-cols-4 gap-4 mb-6">
        {connections.map(c => {
          const Icon = c.icon;
          return (
            <div key={c.name} className="bg-white border border-stone-200 rounded-xl p-5">
              <div className="flex items-start justify-between mb-3">
                <div className={`p-2.5 rounded-lg ${c.bg}`}><Icon className={`w-5 h-5 ${c.color}`} /></div>
                <CheckCircle2 className="w-4 h-4 text-emerald-600" />
              </div>
              <p className="font-medium text-stone-900">{c.name}</p>
              <p className="text-xs text-stone-500 mt-1">{c.handle}</p>
              <p className="text-xs text-emerald-700 mt-2">Connected</p>
            </div>
          );
        })}
      </div>

      {composing && (
        <Modal onClose={() => setComposing(false)} title="Create a post">
          <div className="space-y-4">
            <div>
              <label className="text-xs uppercase tracking-wider text-stone-500 font-medium mb-2 block">Platforms</label>
              <div className="flex gap-2 flex-wrap">
                {["Facebook", "Instagram", "YouTube"].map(p => {
                  const Icon = platformIcon[p];
                  const active = draft.platforms.includes(p);
                  return (
                    <button
                      key={p}
                      onClick={() => togglePlatform(p)}
                      className={`px-3 py-2 rounded-lg text-sm flex items-center gap-2 border transition ${
                        active ? "bg-stone-900 text-amber-50 border-stone-900" : "bg-white text-stone-600 border-stone-200"
                      }`}
                    >
                      <Icon className="w-4 h-4" /> {p}
                    </button>
                  );
                })}
              </div>
            </div>
            <div>
              <label className="text-xs uppercase tracking-wider text-stone-500 font-medium">Content</label>
              <textarea
                value={draft.content}
                onChange={e => setDraft({ ...draft, content: e.target.value })}
                rows={4}
                className="w-full mt-1 px-3 py-2 border border-stone-200 rounded-lg text-sm focus:outline-none focus:border-amber-700"
                placeholder="What's happening at your church?"
              />
              <p className="text-xs text-stone-400 mt-1">{draft.content.length} / 2200 characters</p>
            </div>
            <Input label="Schedule for (optional)" value={draft.when} onChange={v => setDraft({ ...draft, when: v })} />
          </div>
          <div className="flex justify-end gap-2 mt-6">
            <button onClick={() => setComposing(false)} className="px-4 py-2 text-sm text-stone-600">Cancel</button>
            <button onClick={publish} className="px-4 py-2 text-sm bg-stone-900 text-amber-50 rounded-lg hover:bg-stone-800">
              {draft.when ? "Schedule" : "Publish now"}
            </button>
          </div>
        </Modal>
      )}

      <h3 className="font-serif text-xl text-stone-900 mb-4">Recent posts</h3>
      <div className="space-y-3">
        {posts.map(p => {
          const Icon = platformIcon[p.platform] || Share2;
          return (
            <div key={p.id} className="bg-white border border-stone-200 rounded-xl p-5 flex gap-4">
              <div className={`p-2.5 rounded-lg h-fit border ${platformColor[p.platform]}`}>
                <Icon className="w-5 h-5" />
              </div>
              <div className="flex-1">
                <div className="flex items-center gap-2 mb-2">
                  <span className="font-medium text-stone-900">{p.platform}</span>
                  <span className={`text-[10px] uppercase tracking-wider px-2 py-0.5 rounded ${
                    p.status === "Published" ? "bg-emerald-100 text-emerald-800" : "bg-amber-100 text-amber-800"
                  }`}>{p.status}</span>
                  <span className="text-xs text-stone-500">· {p.when}</span>
                </div>
                <p className="text-sm text-stone-700 mb-3">{p.content}</p>
                {p.engagement && (
                  <div className="flex gap-4 text-xs text-stone-500">
                    <span>❤ {p.engagement.likes} likes</span>
                    <span>💬 {p.engagement.comments} comments</span>
                    <span>↗ {p.engagement.shares} shares</span>
                  </div>
                )}
              </div>
            </div>
          );
        })}
      </div>
    </div>
  );
}

